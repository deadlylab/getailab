# ── LLM Provider (required for hypothesis/synthesis/Sauron) ──────────────────
# Local-first default: Ollama — https://ollama.com/  then: ollama serve
LLM_PROVIDER=ollama
LLM_ENDPOINT=http://localhost:11434
# Recommended for loops (stable — do NOT use m3 for loops):
LLM_MODEL=minimax-m2.5:cloud
LLM_MODEL_CODE=minimax-m2.5:cloud
# Local-only fallback:
# LLM_MODEL=dolphin3:latest
# LLM_MODEL_CODE=codellama:latest
# Vision model for Sauron screenshot analysis (Ollama: llava, moondream, etc.)
LLM_MODEL_VISION=llava:latest
# Local Ollama: large persona prompts need time (seconds)
SCIENTIST_HTTP_TIMEOUT=600
OLLAMA_TIMEOUT=600
OLLAMA_NUM_PREDICT=4096
OLLAMA_NUM_PREDICT_CODE=8192

# Or pick a cloud provider explicitly (API key alone does NOT auto-select):
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...          # https://platform.openai.com/api-keys
# LLM_MODEL=gpt-4o

# LLM_PROVIDER=google
# GOOGLE_API_KEY=...             # https://aistudio.google.com/apikey
# LLM_MODEL=gemini-2.0-flash

# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...   # https://console.anthropic.com/settings/keys
# LLM_MODEL=claude-sonnet-4-20250514

# LLM_PROVIDER=auto   # Ollama if reachable, else first cloud key found

# ── Lab identity (shipped example lab is default) ───────────────────────────
LAB_ID=example
# PERSONAS_YAML=personas/example_squad.yaml   # auto from LAB_ID
# Forge your lab: python3 scripts/create_lab.py  then source .env.<lab_id>
# Operator-tuned squads and large vaults stay local — see docs/BUILDER_REPO.md

# ── Service URLs (defaults from data/labs/<LAB_ID>/config/lab.yaml) ─────────
ORACLE_URL=http://localhost:5124
LAB_URL=http://localhost:5135
# ORACLE_PORT=5124
# LAB_PORT=5135
GETAILAB_USER_ID=default

# ── Literature grounding (Crow-style, auto-injected at hypothesis phase) ─────
LITERATURE_SEARCH_ENABLED=true
LITERATURE_MAX_PER_SOURCE=5
LITERATURE_SEARCH_TIMEOUT=30

# ── Council chat (dashboard / --chat) ────────────────────────────────────────
CHAT_MAX_REPLY_CHARS=8000

# ── Docker (override in docker-compose.yml; host .env can stay localhost) ────
# Inside containers, compose sets ORACLE_URL/LAB_URL to service hostnames and
# LLM_ENDPOINT to host.docker.internal so Ollama on the host is reachable.
#
# IMPORTANT: default Ollama binds 127.0.0.1 only — Docker CANNOT reach it.
# Before docker loops:  ./scripts/ollama_for_docker.sh
# Or: OLLAMA_HOST=0.0.0.0 ollama serve
#
# Docker host port maps (defaults match example lab):
# LAB_HOST_PORT=5135
# ORACLE_HOST_PORT=5124
# RESEARCHER_HOST_PORT=5125
# CRITIC_HOST_PORT=5126